# Agent Health - Environment variables for local Docker stack
# Usage: cp .env.docker .env (or merge into existing .env)

# OpenSearch storage (test cases, benchmarks, runs)
OPENSEARCH_STORAGE_ENDPOINT=https://localhost:9200
OPENSEARCH_STORAGE_USERNAME=admin
OPENSEARCH_STORAGE_PASSWORD=My_password_123!@#

# OpenSearch logs/traces (same cluster in local dev)
OPENSEARCH_LOGS_ENDPOINT=https://localhost:9200
OPENSEARCH_LOGS_USERNAME=admin
OPENSEARCH_LOGS_PASSWORD=My_password_123!@#
OPENSEARCH_LOGS_TRACES_INDEX=otel-v1-apm-span-*
OPENSEARCH_LOGS_INDEX=ss4o_logs-otel-*

# OTEL Collector endpoint (for agents to send traces)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
